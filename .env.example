# Cloudflare Account ID，用于拼接 R2 endpoint
ACCOUNT_ID=355c3d5ea1992e0e19a5dea722afff7c

# R2 API Access Key ID
ACCESS_KEY_ID=your_r2_access_key_id

# R2 API Secret Access Key
SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket 名称
BUCKET_NAME=image-buck

# 公开访问图片的自定义域名，例如 https://image.example.com
PUBLIC_BASE_URL=https://image.webutilitykit.com

# 是否在上传前进行本地压缩，true 或 false
ENABLE_LOCAL_COMPRESS=true

# 输出格式：original 表示保留原始扩展名，webp 表示统一转成 WebP
OUTPUT_FORMAT=original

# 压缩后的最大宽度，超出时按比例缩小
MAX_WIDTH=2560

# 压缩后的最大高度，超出时按比例缩小
MAX_HEIGHT=2560

# JPEG 输出质量，范围 1-100
JPEG_QUALITY=85

# WebP 输出质量，范围 1-100
WEBP_QUALITY=82

# PNG 压缩级别，范围 0-9
PNG_COMPRESS_LEVEL=6
